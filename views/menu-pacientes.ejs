<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pacientes</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.2/dist/lux/bootstrap.css">
    <style>
        .logo {
            width: 50px;
            height: auto;
            display: block;
        }

        #firstTimeBtn {
            display: flex;
            text-align: center;
            margin: auto;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg bg-light" data-bs-theme="light">
        <div class="container-fluid">
            <a class="navbar-brand" href="#"><img class="logo" src="img/navimg.svg"></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor03"
                aria-controls="navbarColor03" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarColor03">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Inicio">Inicio
                            <span class="visually-hidden">(current)</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Configuración">Configuración</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/Pacientes">Pacientes</a>
                    </li>
                </ul>
                <form class="d-flex">
                    <input class="form-control me-sm-2" type="search" placeholder="Buscar paciente">
                    <button class="btn btn-outline-primary my-2 my-sm-0" type="submit">Buscar</button>
                </form>
                <div class="d-flex m-1">
                    <button class="btn btn-outline-danger my-2 my-sm-0" data-bs-toggle="modal"
                        data-bs-target="#logOutModal">Cerrar sesión</button>
                </div>
            </div>
        </div>
    </nav>
    <div class="modal" id="logOutModal">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cerrar sesión</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true"></span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>¿Estás seguro de que quieres cerrar la sesión actual?</p>
                </div>
                <div class="modal-footer">
                    <a href="/logOut"><button type="button" class="btn btn-danger">Cerrar sesión</button></a>
                </div>
            </div>
        </div>
    </div>


    <div class="m-5">
        <table class="table table-hover">


            <% if (doctor.data && doctor.data.length> 0) { %>
                <thead>
                    <tr>
                        <th scope="col">Apellido</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">DNI</th>
                    </tr>
                </thead>
                <tbody>
                    <% doctor.data.slice(0,20).forEach(paciente=> { %>

                        <a href="buscarPaciente/<%= paciente.dni %>">
                            <tr>
                                <td scope="col">
                                    <%= paciente.surname %>
                                </td>
                                <td scope="col">
                                    <%= paciente.name %>
                                </td>
                                <td scope="col">
                                    <%= paciente.dni %>
                                </td>
                            </tr>
                        </a>
<!-- hacer el sistema de pages -->

                        <% }); %>
                </tbody>
                <%} else { console.log(doctor.data[0].dni);%>
                    <a id="firstTimeBtn" href="/crearPaciente"><button id="firstTimeBtn"
                            class="btn btn-outline-info">Ingresa tu primer paciente</button></a>
                    <% } %>
        </table>
    </div>


</body>

</html>

</html>